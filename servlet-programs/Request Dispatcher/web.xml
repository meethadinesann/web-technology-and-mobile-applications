<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

 <servlet>
  <servlet-name>Servlet1</servlet-name>
  <servlet-class>com.dispatcher.Servlet1</servlet-class>
 </servlet>

 <servlet>
  <servlet-name>Servlet2</servlet-name>
  <servlet-class>com.dispatcher.Servlet2</servlet-class>
 </servlet>

 <servlet-mapping>
  <servlet-name>Servlet1</servlet-name>
  <url-pattern>/Servlet1</url-pattern>
 </servlet-mapping>

 <servlet-mapping>
  <servlet-name>Servlet2</servlet-name>
  <url-pattern>/Servlet2</url-pattern>
 </servlet-mapping>

</web-app>
